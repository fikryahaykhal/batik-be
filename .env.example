PORT=3000
DATABASE_URL="file:./dev.db"
JWT_SECRET="super-secret-key-change-me"

# Midtrans Snap — wajib untuk checkout "Bayar sekarang" (Snap sandbox/production).
# Sandbox: https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# Hanya jika benar-benar perlu: izinkan checkout tanpa Midtrans (tanpa Snap, bukan untuk uji bayar).
# ALLOW_CHECKOUT_WITHOUT_PAYMENT=true
